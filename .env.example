DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Local development database. Leave empty to use Django's default SQLite config.
DATABASE_URL=

# Palworld REST API. Keep this private; do not expose the Palworld API directly to the internet.
PALWORLD_API_BASE_URL=http://127.0.0.1:8212/v1/api
PALWORLD_API_USERNAME=admin
PALWORLD_API_PASSWORD=change-me
PALWORLD_API_TIMEOUT=5

# Optional shared secret for a future collector/agent ingest endpoint.
PALWORLD_INGEST_TOKEN=change-me

# Local map asset caches. The webapp only serves local files from these folders.
PALWORLD_MAP_TILE_CACHE_DIR=tile-cache
PALWORLD_MAP_MAX_ZOOM=6
PALWORLD_MAP_ICON_CACHE_DIR=icon-cache
